{
  "name": "supawrapper",
  "version": "1.0.3",
  "description": "A TypeScript package that wraps the Supabase client in a reusable class and exposes common methods for Create, Read, Update, and Delete operations.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "author": "gomzyyy",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "tus-js-client": "^4.3.1"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}
